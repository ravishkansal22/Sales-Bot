# =============================================================================
# Ghost Negotiator – Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values for your local setup.

# --- Database ----------------------------------------------------------------
# Async PostgreSQL connection string (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ghost_negotiator

# --- Redis -------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# --- LLM Provider ------------------------------------------------------------
# Supported values: gemini, openai
LLM_PROVIDER=gemini

# Google Generative AI
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Default model identifier (provider-specific).
# Gemini examples : gemini-2.0-flash, gemini-2.5-pro
# OpenAI examples : gpt-4o, gpt-4o-mini
DEFAULT_MODEL=gemini-2.0-flash

# --- Simulation --------------------------------------------------------------
# Number of Monte-Carlo rollouts per strategy.
ROLLOUT_COUNT=3

# --- Debug -------------------------------------------------------------------
# Set to true for verbose SQL logging and other debug output.
DEBUG=false
